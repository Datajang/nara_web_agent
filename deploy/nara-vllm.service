[Unit]
Description=vLLM EXAONE Server
After=network.target

[Service]
Type=simple
User=searching-doc-rag
WorkingDirectory=/app/nara-web
ExecStart=/home/searching-doc-rag/my_project/.venv/bin/python3 -m vllm.entrypoints.openai.api_server \
    --model LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct \
    --port 8002 \
    --host 127.0.0.1 \
    --max-model-len 8192 \
    --gpu-memory-utilization 0.90 \
    --dtype float16 \
    --trust-remote-code
Restart=always
RestartSec=10
TimeoutStartSec=300
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
